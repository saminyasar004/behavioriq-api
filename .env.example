# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/behavioriq
# Docker-internal Database URL (used by docker-compose)
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/behavioriq

# Server
PORT=5000
NODE_ENV=development

# Redis (for caching)
REDIS_URL=redis://localhost:6380
# Docker-internal Redis URL (used by docker-compose)
DOCKER_REDIS_URL=redis://redis:6379

# ML Service (external, separate repo)
ML_SERVICE_URL=http://localhost:8001

# Gemini (optional; explanations use generic copy when unset)
GEMINI_AI_API_KEY=your_gemini_api_key_here
